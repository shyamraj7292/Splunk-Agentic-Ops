# =============================================================================
# Sentinel Triage Agent - environment configuration
#
# Copy this file to ".env" and fill in the values for your environment.
# Every value has a safe default so the agent runs fully offline in
# "mock" mode with ZERO configuration - this is the recommended way to
# try the demo first.
# =============================================================================

# -----------------------------------------------------------------------------
# Data source mode
#   mock - use the bundled BOTS-inspired scenario data, no Splunk required
#   live - connect to a real Splunk instance via the Splunk MCP Server
# -----------------------------------------------------------------------------
SPLUNK_MODE=mock

# -----------------------------------------------------------------------------
# Splunk MCP Server connection (only used when SPLUNK_MODE=live)
# The Splunk MCP Server (GA Feb 2026) can be run locally and exposes tools
# such as splunk_search, splunk_list_indexes, saia_generate_spl,
# saia_explain_spl and saia_ask_splunk_question.
#
# Transport: "stdio" (spawn the server as a subprocess) or "sse"/"http"
# (connect to an already-running server over the network).
# -----------------------------------------------------------------------------
MCP_TRANSPORT=stdio
# Command used to launch the MCP server for stdio transport, e.g.:
#   MCP_SERVER_COMMAND=uvx splunk-mcp-server
MCP_SERVER_COMMAND=
# URL used for sse/http transport, e.g. http://localhost:8765/sse
MCP_SERVER_URL=

# Splunk REST connection details, passed through to the MCP server
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=
SPLUNK_TOKEN=
SPLUNK_VERIFY_SSL=false

# -----------------------------------------------------------------------------
# LLM reasoning backend - first match wins:
#   1) FOUNDATION_SEC_BASE_URL set      -> Splunk Foundation-sec hosted model
#   2) ANTHROPIC_API_KEY set            -> Anthropic Claude
#   3) neither set                      -> deterministic simulated reasoning
#                                          (works fully offline, no API keys)
# -----------------------------------------------------------------------------

# Splunk Foundation-sec hosted model (OpenAI-compatible endpoint)
FOUNDATION_SEC_BASE_URL=
FOUNDATION_SEC_API_KEY=
FOUNDATION_SEC_MODEL=foundation-sec-8b-instruct

# Anthropic fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Web UI
# -----------------------------------------------------------------------------
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Maximum ReAct steps the agent will take before forcing a verdict
AGENT_MAX_STEPS=6

# Artificial delay (seconds) between trace events in mock mode, so the web UI
# visibly "thinks" through each step instead of dumping the whole trace at
# once. Ignored in live mode (real tool calls already take time). Set to 0
# for instant output (e.g. in automated tests).
DEMO_STEP_DELAY_SECONDS=0.5
